Ref "account_userId_fkey":"user"."id" < "account"."userId" [delete: cascade]

Ref "claim_evidence_claim_id_fkey":"dealership_claims"."id" < "claim_evidence"."claim_id" [delete: cascade]

Ref "comp_grants_workspace_id_fkey":"workspaces"."id" < "comp_grants"."workspace_id"

Ref "dealership_aliases_dealership_id_fkey":"dealerships"."id" < "dealership_aliases"."dealership_id"

