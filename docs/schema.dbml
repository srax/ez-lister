  Checks {
    `(((type = 'personal'::text) AND (user_id IS NOT NULL) AND (organization_id IS NULL)) OR ((type = 'organization'::text) AND (user_id IS NULL) AND (organization_id IS NOT NULL)))` [name: 'workspaces_check']
