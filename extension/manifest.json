{
  "manifest_version": 3,
  "name": "Carxpert",
  "version": "0.2.0",
  "description": "List dealership inventory to Facebook Marketplace in one click.",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.alexandriatoyota.com/*",
    "https://*.facebook.com/*",
    "http://127.0.0.1:3737/*",
    "http://localhost:3737/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "Carxpert — open panel",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.alexandriatoyota.com/*"],
      "js": ["lib/mappers.js", "dealerContent.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.facebook.com/*", "https://web.facebook.com/*"],
      "js": ["lib/mappers.js", "facebookContent.js"],
      "run_at": "document_idle"
    }
  ]
}
