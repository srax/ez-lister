{
  "manifest_version": 3,
  "name": "ezlist",
  "version": "0.1.0",
  "description": "Create Facebook Marketplace vehicle drafts from dealership listing pages.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.alexandriatoyota.com/*",
    "https://*.facebook.com/*",
    "http://127.0.0.1:3737/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "ezlist",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.alexandriatoyota.com/*"],
      "js": ["dealerContent.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.facebook.com/*", "https://web.facebook.com/*"],
      "js": ["facebookContent.js"],
      "run_at": "document_idle"
    }
  ]
}
