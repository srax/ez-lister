# Carxpert backend — copy to backend/.env and fill in. Our key, our cost: users never
# supply a key. Real env (Railway) always wins; .env only fills gaps for local dev.

# ---- AI (required for /api/ai/*) ----
OPENAI_API_KEY=sk-...your-key-here...
# DESCRIBE_MODEL=gpt-4o-mini
# TRANSLATE_MODEL=gpt-4o-mini
# TRANSLATE_MODEL_STRONG=gpt-4o

# ---- Postgres ----
# Railway injects DATABASE_URL (internal, no TLS). For local migration runs over the
# public proxy, paste DATABASE_PUBLIC_URL here and set PGSSL=require.
# DATABASE_URL=postgresql://user:pass@host:port/dbname
# PGSSL=require

# ---- Server ----
# NODE_ENV=production        # minimal /health, no dev routes, no stack traces
# PORT=3737                  # Railway injects PORT
# HOST=0.0.0.0               # auto: 0.0.0.0 on Railway, 127.0.0.1 locally

# ---- Extension identity / CORS ----
# EXTENSION_ID=ejagngoidhjkjoadbbijjkpdgelklael
# EXTENSION_IDS_DEV=abcd...,efgh...   # extra unpacked dev IDs (non-production only)
# MIN_EXTENSION_VERSION=0.2.0

# ---- Legacy shared-secret gate (retired in A5 once bearer auth lands) ----
# When set, the extension must send header  x-carxpert-token: <same value>
# CARXPERT_TOKEN=
# RATE_MAX=40                # AI requests per minute per client IP
