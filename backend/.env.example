# =============================================================================
# Carxpert backend — environment template
# -----------------------------------------------------------------------------
# HOW THIS FILE IS USED:
#   The backend reads  backend/.env  ONLY  (see backend/env.js). The repo-root
#   .env is NOT read by the backend. So:  cp backend/.env.example backend/.env
#   and fill in values below.
#
#   Real env (Railway) always wins; .env only fills keys that aren't already set.
#
# LEGEND:
#   [required-local]  you must set this to run the backend locally
#   [required-prod]   needed in production (Railway) — optional for basic local dev
#   [optional]        has a sane default
#   ⚠ LOCAL:          what to change vs the production value
# =============================================================================


# ---- Server / mode ----------------------------------------------------------
# Leave NODE_ENV UNSET for local dev. Setting it to "production" (or running with
# any RAILWAY_* var present) turns on production mode: dev routes + HTML fixtures
# are disabled, /health is minimal, stack traces are hidden, and the AI token gate
# fails closed. isProduction() = (NODE_ENV==='production' OR any RAILWAY_* set).
# NODE_ENV=production           # [required-prod]  ⚠ LOCAL: leave this commented out

# PORT=3737                     # [optional] listen port (Railway injects PORT)
# HOST=127.0.0.1                # [optional] auto: 0.0.0.0 on Railway, 127.0.0.1 local


# ---- Postgres ---------------------------------------------------------------
# [required-local] Connection string. Migrations run on boot.
#   Local Postgres (recommended for dev — full isolation from prod data):
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/carxpert
#   ⚠ LOCAL: the production DATABASE_URL points at *.railway.internal, which is
#   ONLY reachable from inside Railway. To use the Railway DB from your laptop,
#   paste DATABASE_PUBLIC_URL from the Railway dashboard here and set PGSSL=require
#   (do this against a STAGING db, never production).
# PGSSL=require                 # [optional] force TLS, accept Railway's proxy cert


# ---- AI (OpenAI) ------------------------------------------------------------
OPENAI_API_KEY=sk-...           # [required-local for /api/ai/*] our key, our cost
# DESCRIBE_MODEL=gpt-4o-mini            # [optional] description model
# TRANSLATE_MODEL=gpt-4o-mini           # [optional] default translate model
# TRANSLATE_MODEL_STRONG=gpt-4o         # [optional] strong-language translate model
# AI_DAILY_LIMIT=100                    # [optional] per-kind daily cap per user (bearer mode)

# AI auth gate:
#   token  (default) = shared-secret header x-carxpert-token (open in dev if unset)
#   bearer           = per-user entitlement + daily limit (the intended end state)
# AI_AUTH_MODE=token            # [optional] leave as token for simple local AI testing
# CARXPERT_TOKEN=               # [required-prod in token mode] shared secret; if unset,
                                #   the AI gate is OPEN in dev and CLOSED in production
# RATE_MAX=40                   # [optional] token-mode per-IP AI requests/min


# ---- Better Auth (Google OAuth + sessions + bearer) -------------------------
# [required-prod]  Base URL of THIS backend. Used for OAuth callbacks + success URLs.
# BETTER_AUTH_URL=http://127.0.0.1:3737   # ⚠ LOCAL: use your local URL, not the prod one
# BETTER_AUTH_SECRET=           # [required-prod] signing secret (generate a random 32+ byte hex)
# BETTER_AUTH_API_KEY=          # [optional] enables the @better-auth/infra dashboard plugin

# Google OAuth credentials (both required to enable sign-in). The redirect URI
# (e.g. http://127.0.0.1:3737/api/auth/callback/google) must be registered in the
# Google Cloud console for local sign-in to work.
# GOOGLE_CLIENT_ID=             # [required-prod]
# GOOGLE_CLIENT_SECRET=         # [required-prod]

# AUTH_CODE_TTL_SECONDS=600     # [optional] one-time extension-auth code TTL (default 60)


# ---- Extension identity / CORS ----------------------------------------------
# The pinned extension ID (derived from the manifest `key`). This is the only
# chrome-extension:// origin allowed by CORS in production.
# EXTENSION_ID=nfpnkiknibofeiicekdehonjmpnonaeh    # [optional] matches the manifest key
# EXTENSION_IDS_DEV=            # [optional, dev only] extra unpacked dev IDs, comma-separated
# MIN_EXTENSION_VERSION=0.2.0   # [optional] kill-switch: min supported extension version


# ---- Entitlement lease (ES256 JWS, verified offline in the extension) -------
# [required-prod] Sign the entitlement lease. If unset, /api/me returns lease:null
# and all paid List/Fill actions gate off. Accepts raw PKCS8 PEM (with \n) OR a
# base64-encoded PEM blob.
# LEASE_PRIVATE_KEY_PEM=        # [required-prod]
# LEASE_KID=lease-prod-xxxxxxxx # [required-prod] current key id (JWS kid)
# LEASE_PUBLIC_KEY_PEM_PREV=    # [optional] previous public key, kept in JWKS during rotation
# LEASE_KID_PREV=               # [optional] previous kid


# ---- Stripe (billing) -------------------------------------------------------
# ⚠ LOCAL: use TEST keys (sk_test_...), a test price id, and a test webhook secret
# from `stripe listen`. NEVER exercise live keys from a laptop. If left unset,
# billing routes simply return 503 and you can develop everything else.
# STRIPE_SECRET_KEY=sk_test_... # [required-prod]
# STRIPE_PRICE_ID=price_...     # [required-prod] the subscription price
# STRIPE_WEBHOOK_SECRET=whsec_... # [required-prod] webhook signature secret


# ---- Admin ops --------------------------------------------------------------
# ADMIN_TOKEN=                  # [required-prod] gates /api/admin/* (header x-admin-token)


# ---- Sold-scan worker -------------------------------------------------------
# ⚠ LOCAL: keep this OFF unless you specifically want the worker hitting the live
# dealer website every 30 minutes.
# SOLD_SCAN_ENABLED=0           # [optional] 1/true/yes starts the in-process worker


# ---- Dealer-request email (Resend) ------------------------------------------
# When a user submits the "request dealership" form (an unrecognized platform),
# the request is emailed to EMAIL_TO_ADMIN. Unset → the email is skipped (the
# request still records in dealer_requests). Uses Resend's HTTP API (no SMTP dep).
# RESEND_API_KEY=re_...         # [optional] Resend API key
# EMAIL_FROM=CarXprt <requests@carxprt.com>   # [optional] verified Resend sender
# EMAIL_TO_ADMIN=admin@carxprt.com            # [optional] recipient(s), comma-separated
