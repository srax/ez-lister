# Carxpert backend — copy to backend/.env and fill in.
# Our key, our cost: users never supply a key.

OPENAI_API_KEY=sk-...your-key-here...

# Optional overrides
# DESCRIBE_MODEL=gpt-4o-mini
# TRANSLATE_MODEL=gpt-4o
# PORT=3737

# Optional shared-secret gate. Leave unset for local dev (open).
# When set, the extension must send header  x-carxpert-token: <same value>
# CARXPERT_TOKEN=

# Requests per minute per IP (protects the key during testing)
# RATE_MAX=40
